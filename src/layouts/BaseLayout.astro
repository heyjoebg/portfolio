---
import Navigation from '../components/layout/Navigation.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "I'm a self-taught Senior Product Designer with 10+ years of experience transforming complex business and user challenges into clean, scalable digital solutions.",
  ogImage = '/images/og_jonathan_beltran_senior_product_designer.jpg',
} = Astro.props;

const pageTitle = `${title} - Jonathan Beltrán - Senior Product Designer`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.toString()} />

    <!-- Favicons -->
    <link rel="shortcut icon" href="/images/favicon.png" type="image/x-icon" />
    <link rel="apple-touch-icon" href="/images/app-icon.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Open+Sans:wght@300;400;600;700;800&family=Montserrat:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="hj2025">
    <Navigation />
    <slot />
  </body>
</html>
